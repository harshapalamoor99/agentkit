# Copy to .env and fill in your gateway credentials. Real env vars override .env.
LITELLM_API_KEY=sk-...
LITELLM_API_BASE=https://your-gateway/v1

# Prefer a fast/lite model to stay under the <2s latency SLA.
# Use the BARE model id the gateway advertises (GET /v1/models) — no "openai/" prefix.
LITELLM_MODEL=gemini-2.5-flash-lite-genaicenter-us

# Embedding model your gateway/team is allowed to use (semantic-match eval).
EMBEDDING_MODEL=text-embedding-005-genaicenter-us

# Keep the LLM warm for an entire demo/low-traffic session (avoids cold-start latency
# after idle gaps). Leave OFF for steady production traffic.
KEEPWARM_ENABLED=1
KEEPWARM_INTERVAL_S=15
