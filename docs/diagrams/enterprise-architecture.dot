digraph enterprise {
  rankdir=TB;
  bgcolor="white";
  labelloc="t";
  fontname="Helvetica-Bold";
  fontsize=20;
  label="Production Architecture & RealPage Enterprise Matrix (RP-01..15)";
  node [fontname="Helvetica", fontsize=10, shape=box, style="filled,rounded", penwidth=1.3];
  edge [fontname="Helvetica", fontsize=9, color="#555555"];

  gw   [label="API Gateway / Web UI\n+ POST /api/webhook", fillcolor="#E8EAF6", color="#3949AB"];
  q    [label="Message Queue\nKafka worker  (stdin fallback)", fillcolor="#E8EAF6", color="#3949AB"];

  subgraph cluster_core {
    label="LangGraph Supervisor  (per-record, async, 1.8s deadline)";
    fontname="Helvetica-Bold"; fontsize=12; color="#1976D2"; bgcolor="#F5F9FF"; style="rounded";
    core [label="intake → safety → [sanitize] → context → llm → parse → evaluate → emit/abort", fillcolor="white", color="#1976D2"];
  }

  subgraph cluster_caps {
    label="Enterprise capability modules";
    fontname="Helvetica-Bold"; fontsize=12; color="#558B2F"; bgcolor="#F6FBF0"; style="rounded";
    geo  [label="geo.py\nRP-04 tz + quiet hours", fillcolor="white", color="#558B2F"];
    pii  [label="pii.py\nRP-08 tokenize / mask", fillcolor="white", color="#558B2F"];
    ten  [label="tenants.py\nRP-07/10 brand + portfolio", fillcolor="white", color="#558B2F"];
    cb   [label="circuit_breaker.py\nRP-11 breaker", fillcolor="white", color="#558B2F"];
    wf   [label="workflow.py\nRP-06 state cancel/rewrite", fillcolor="white", color="#558B2F"];
    asset[label="config asset-class\nRP-09 regulated routing", fillcolor="white", color="#558B2F"];
  }

  subgraph cluster_obs {
    label="Governance · Observability · Eval";
    fontname="Helvetica-Bold"; fontsize=12; color="#C2185B"; bgcolor="#FFF5F8"; style="rounded";
    lin  [label="lineage  RP-12\nprompt ver · few-shot ids ·\ntokens · input snapshot", fillcolor="white", color="#C2185B"];
    judge[label="LLM-as-judge  RP-13\nfaithfulness ≥ 0.95\ncontext_precision ≥ 0.90", fillcolor="white", color="#C2185B"];
    tel  [label="telemetry.py  RP-15\nclosed-loop → Kafka / JSONL", fillcolor="white", color="#C2185B"];
    audit[label="audit + structured logs\n(per-node, per-record)", fillcolor="white", color="#C2185B"];
  }

  llmsvc [label="LLM provider\n(LiteLLM gateway / Anthropic /\nOpenAI / Azure / Gemini)", shape=cylinder, fillcolor="#FCE4EC", color="#C2185B"];
  store  [label="Output + Audit Store\n(JSONL / Postgres)", shape=cylinder, fillcolor="#E8F5E9", color="#2E7D32"];
  dlq    [label="Dead-Letter Queue + Replay  (G5)\nsafe-aborted records → JSONL / Kafka\nreplay re-runs recovered records", shape=cylinder, fillcolor="#FFEBEE", color="#C62828"];

  gw -> q -> core;
  core -> geo; core -> pii; core -> ten; core -> cb; core -> wf; core -> asset;
  core -> llmsvc [label="async + timeout", color="#C2185B"];
  cb -> llmsvc [style=dashed, color="#C2185B", label="protect"];
  core -> lin; core -> judge; core -> tel; core -> audit;
  lin -> store; audit -> store; tel -> q [style=dashed, label="outcome events\n(closed-loop, not training)", color="#2E7D32"];
  core -> dlq [label="safe no-send abort", color="#C62828", fontcolor="#C62828"];
  dlq -> core [style=dashed, label="replay", color="#C62828", fontcolor="#C62828"];
  wf -> gw [style=dashed, label="cancel/rewrite\non webhook event", color="#F57C00"];
}
